# ====== MongoDB ======
# Your MongoDB Atlas connection string. Include the database name at the end,
# e.g. mongodb+srv://user:pass@cluster.mongodb.net/meetmind?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://gaurisalaskar98_db_user:Gauri1234@campusshare.gqg5l9r.mongodb.net/?appName=campusshare

# ====== Auth ======
# Any long random string — used to sign JWTs
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_HOURS=72

# ====== Anthropic Claude ======
ANTHROPIC_API_KEY=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
# Optional override, defaults to claude-sonnet-4-6 in code
ANTHROPIC_MODEL=claude-sonnet-4-6

# ====== Hindsight (Vectorize) ======
# Base URL of your Hindsight Cloud instance, e.g. https://api.hindsight.vectorize.io
HINDSIGHT_BASE_URL=
# API key / bearer token from ui.hindsight.vectorize.io
HINDSIGHT_API_KEY=
# Tenant slug if your Hindsight Cloud project uses one in the URL path
# (/v1/{tenant}/banks/{bank_id}/...). Leave blank if not applicable — code
# will fall back to /v1/banks/{bank_id}/... in that case.
HINDSIGHT_TENANT=

# ====== Sarvam AI (voice meeting notes) ======
# API key from dashboard.sarvam.ai — required for voice-recorded meeting notes
SARVAM_API_KEY=

# ====== App ======
FLASK_ENV=development
PORT=5000
# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
